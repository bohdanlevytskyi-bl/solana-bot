# =============================================================================
# Pump.fun Sniper Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- RPC Connection ---
# Sign up at https://helius.dev → Dashboard → copy your RPC URL
# Free tier: 100k requests/day. Alternative: https://quicknode.com
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# WebSocket URL for real-time monitoring (same provider, starts with wss://)
WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# --- Wallet ---
# Your Solana wallet private key as a JSON byte array.
# How to get it:
#   Option A: Phantom → Settings → Security → Export Private Key → decode base58 to byte array
#   Option B: solana-keygen → use the JSON keypair file contents
#   Option C: Use bs58 to decode your base58 private key: require('bs58').decode('your_key')
# NEVER share this key. NEVER commit this file.
PRIVATE_KEY=[0,0,0,0]

# --- Execution Mode ---
# paper      = simulated trades, no real SOL spent (DEFAULT — safe for testing)
# production = real trades with real SOL (be careful!)
MODE=paper

# --- Sniping Mode ---
# aggressive = buy every new token immediately (fast, risky)
# filtered   = apply filters before buying (slower, safer)
SNIPE_MODE=filtered

# --- Trade Settings ---
# Amount of SOL to spend per snipe (start small! 0.01-0.05 for testing)
BUY_AMOUNT_SOL=0.01

# Max slippage tolerance in %. Pump.fun is volatile, 15-30% is typical.
SLIPPAGE_PCT=25

# --- Auto-Sell Thresholds ---
# Auto-sell when price is UP this % from your buy price
TAKE_PROFIT_PCT=50

# Auto-sell when price is DOWN this % from your buy price
STOP_LOSS_PCT=30

# --- Priority Fee ---
# Priority fee in lamports for faster transaction inclusion
# 1 SOL = 1,000,000,000 lamports
# 100000 lamports = 0.0001 SOL (good starting point)
PRIORITY_FEE_LAMPORTS=100000
